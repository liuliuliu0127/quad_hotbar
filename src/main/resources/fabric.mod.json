{
  "schemaVersion": 1,
  "id": "double_hotbar",
  "version": "${version}",

  "name": "Quad Hotbar",
  "description": "Modified version of Double Hotbar Mod which adds more than two hotbars that displays the third row of the inventory on the HUD. ",
  "authors": [
    "sidezbros",
    "liuliuliu0127",
    "deepseek"
  ],
  "contact": {
    "homepage": "https://github.com/liuliuliu0127/quad_hotbar",
    "sources": "https://github.com/liuliuliu0127/quad_hotbar",
    "issues": "https://github.com/liuliuliu0127/quad_hotbar/issues"
  },

  "license": "GPLv3",
  "icon": "assets/double_hotbar/icon.png",

  "environment": "*",
  "entrypoints": {
    "client": [
      "com.sidezbros.double_hotbar.DoubleHotbar"
    ],
    "modmenu": [
        "com.sidezbros.double_hotbar.DHMenuIntegration"
    ]
  },
  "mixins": [
    "double_hotbar.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.17.3",
    "fabric-api": "*",
    "minecraft": "~1.21.9",
    "java": ">=21"
  }
}
